# =============================================================================
# TrustMeBro — environment variables
# Copy to .env.local and fill in. Never commit .env.local.
# =============================================================================

# Supabase — public (used by browser + SSR)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server-only, never expose to client
SUPABASE_SERVICE_ROLE_KEY=

# NBA stats provider (balldontlie.io free tier)
BALLDONTLIE_API_KEY=

# Bookmaker odds — The Odds API (https://the-odds-api.com).
# Free tier = 500 requests/month; player props cost 10x base rate, so a single
# daily snapshot on a busy NBA night burns most of it. Without this key, the
# /api/cron/track-odds endpoint skips, and /api/cron/generate-predictions
# produces zero picks (the engine requires real odds to emit a pick).
ODDS_API_KEY=

# Protects /api/cron/* from unauthenticated invocation
CRON_SECRET=

# Google Gemini — powers the in-app chatbot AND the engine-take previews on
# /news (filled in for games with no real writer commentary yet).
# Free tier (1,500 req/day on Gemini 2.5 Flash). Get a key at:
#   https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# News aggregator — NewsAPI.org. Optional. Without it the /news feed still
# pulls ESPN, Bleacher Report, Yahoo and CBS RSS; NewsAPI just adds breadth
# from the AP wire, NY Times, etc. Free tier: 100 req/day with a 24h delay.
# Get a key at: https://newsapi.org/register
NEWS_API_KEY=

# Paywall / pricing-tier feature flag. Default off — every visitor sees every
# pick. Set to "true" to re-enable the VIP gate, lock icons, "Unlock Pick"
# CTAs and the homepage pricing section without redeploying code.
NEXT_PUBLIC_PAYWALL_ENABLED=

# Vercel automation token — used by scripts/vercel-setup.mjs to disable
# Deployment Protection and sync env vars without manual dashboard work.
# Create at: https://vercel.com/account/settings/tokens (scope to your team)
VERCEL_TOKEN=
