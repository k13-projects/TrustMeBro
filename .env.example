# NBA live data — https://www.balldontlie.io
BALLDONTLIE_API_KEY=

# Supabase — https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase key (do NOT prefix with NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret for /api/cron/* endpoints. Vercel Cron sends this as
# `Authorization: Bearer ${CRON_SECRET}`.
CRON_SECRET=

# Bookmaker odds provider (e.g. The Odds API: https://the-odds-api.com).
# Optional for now; track-odds cron will no-op without it.
ODDS_API_KEY=
